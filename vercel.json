{
  "crons": [
    {
      "path": "/api/cron/news",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/conflicts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/weather",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/markets",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/flights",
      "schedule": "0 12 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
